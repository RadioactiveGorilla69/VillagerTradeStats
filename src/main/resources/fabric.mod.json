	"authors": [
		"RadioactiveGorilla69"
	],
	"contact": {
		"sources": "https://github.com/RadioactiveGorilla69/VillagerTradeStats"
	},
	"license": "MIT",
	"icon": "assets/villagertradestats/icon.png",
	"environment": "client",
	"entrypoints": {
		"main": [
			"com.radioactivegorilla.VillagerTradeStats"
		],
		"client": [
			"com.radioactivegorilla.VillagerTradeStatsClient"
		],
		"modmenu": [
			"com.radioactivegorilla.config.ModMenuIntegration"
		]
	},
	"mixins": [
		"villagertradestats.mixin.json"
	],
	"depends": {
		"fabricloader": ">=0.17.2",
		"fabric-api": "*",
		"minecraft": ">=26.1",
		"java": ">=25",
		"yet_another_config_lib_v3": ">=3.9.3+26.1-fabric"
	}
